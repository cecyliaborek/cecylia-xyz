---
import '../styles/global.css';
import {
  getBlogUrl,
  getHomeUrl,
  languages,
  ui,
  type Language,
} from '../lib/site';

interface Props {
  title: string;
  description?: string;
  lang: Language;
  active?: 'home' | 'posts';
  alternateUrls?: Partial<Record<Language, string>>;
}

const {
  title,
  description = ui[Astro.props.lang].home.intro,
  lang,
  active,
  alternateUrls = {},
} = Astro.props;
const copy = ui[lang];
const pageTitle =
  title === copy.siteName ? title : `${title} | ${copy.siteName}`;

const navItems = [
  { label: copy.nav.posts, href: getBlogUrl(lang), key: 'posts' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="mx-auto w-full max-w-[42rem] px-5 py-6 sm:px-6 sm:py-8">
      <header
        class="flex flex-col gap-4 font-sans text-[0.8125rem] sm:flex-row sm:items-center sm:justify-between"
      >
        <a
          class="text-ink no-underline transition hover:underline"
          href={getHomeUrl(lang)}
        >
          {copy.navTitle}
        </a>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-3">
          <nav
            class="flex flex-wrap gap-x-4 gap-y-2"
            aria-label={copy.a11y.primaryNavigation}
          >
            {
              navItems.map((item) => (
                <a
                  class:list={[
                    'text-muted no-underline transition hover:text-ink hover:underline',
                    active === item.key && 'text-ink underline',
                  ]}
                  href={item.href}
                  aria-current={
                    active === item.key && item.key === 'posts'
                      ? 'page'
                      : undefined
                  }
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <nav
            class="text-muted flex items-center gap-2 text-xs"
            aria-label={copy.a11y.languageSwitch}
          >
            {
              languages.map((language, index) => (
                <>
                  {index > 0 && (
                    <span class="text-line" aria-hidden="true">
                      /
                    </span>
                  )}
                  <a
                    class:list={[
                      'no-underline transition hover:text-ink hover:underline',
                      language === lang && 'text-ink underline',
                    ]}
                    href={alternateUrls[language] ?? getHomeUrl(language)}
                    aria-current={language === lang ? 'true' : undefined}
                  >
                    {language.toUpperCase()}
                  </a>
                </>
              ))
            }
          </nav>
        </div>
      </header>

      <main class="py-8 sm:py-10">
        <slot />
      </main>

      <footer
        id="contact"
        class="text-muted mt-16 flex flex-col gap-2 font-sans text-[0.8125rem] sm:mt-20 sm:flex-row sm:items-center sm:justify-between"
      >
        <p>
          {copy.home.contact}{' '}
          <a class="text-ink hover:underline" href="mailto:hello@example.com"
            >hello@example.com</a
          >
        </p>
        <p>© {new Date().getFullYear()} {copy.siteName}</p>
      </footer>
    </div>
  </body>
</html>
