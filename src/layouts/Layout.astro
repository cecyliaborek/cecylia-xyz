---
import '../styles/global.css';
import {
  getBlogUrl,
  getHomeUrl,
  languages,
  ui,
  type Language,
} from '../lib/site';

interface Props {
  title: string;
  description?: string;
  lang: Language;
  active?: 'home' | 'posts';
  alternateUrls?: Partial<Record<Language, string>>;
}

const {
  title,
  description = ui[Astro.props.lang].siteName,
  lang,
  active,
  alternateUrls = {},
} = Astro.props;
const copy = ui[lang];
const pageTitle =
  title === copy.siteName ? title : `${title} | ${copy.siteName}`;

const navItems = [
  { label: copy.nav.posts, href: getBlogUrl(lang), key: 'posts' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="mx-auto w-full max-w-[42rem] px-5 py-5 sm:px-6 sm:py-8">
      <header
        class="flex flex-wrap items-center justify-between gap-x-5 gap-y-3 font-sans text-base sm:text-[0.875rem]"
      >
        <a
          class="text-ink text-[1.0625rem] no-underline transition hover:underline sm:text-[0.875rem]"
          href={getHomeUrl(lang)}
        >
          {copy.navTitle}
        </a>
        <div class="flex flex-wrap items-center justify-end gap-x-5 gap-y-2">
          <nav
            class="flex flex-wrap gap-x-4 gap-y-2"
            aria-label={copy.a11y.primaryNavigation}
          >
            {
              navItems.map((item) => (
                <a
                  class:list={[
                    'text-muted -my-2 inline-block py-2 no-underline transition hover:text-ink hover:underline sm:my-0 sm:py-0',
                    active === item.key && 'text-ink underline',
                  ]}
                  href={item.href}
                  aria-current={active === item.key ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <nav
            class="text-muted flex items-center gap-2"
            aria-label={copy.a11y.languageSwitch}
          >
            {
              languages.map((language, index) => (
                <>
                  {index > 0 && (
                    <span class="text-line" aria-hidden="true">
                      /
                    </span>
                  )}
                  <a
                    class:list={[
                      '-my-2 inline-block py-2 no-underline transition hover:text-ink hover:underline sm:my-0 sm:py-0',
                      language === lang && 'text-ink underline',
                    ]}
                    href={alternateUrls[language] ?? getHomeUrl(language)}
                    aria-current={language === lang ? 'true' : undefined}
                  >
                    {language.toUpperCase()}
                  </a>
                </>
              ))
            }
          </nav>
        </div>
      </header>

      <main class="py-7 sm:py-10">
        <slot />
      </main>

      <footer
        id="contact"
        class="text-muted mt-16 flex flex-col gap-2 font-sans text-[0.8125rem] sm:mt-20 sm:flex-row sm:items-center sm:justify-between"
      >
        <p>
          {copy.footer.contact}{' '}
          <a class="text-ink hover:underline" href="mailto:hello@example.com"
            >hello@example.com</a
          >
        </p>
        <p>© {new Date().getFullYear()} {copy.siteName}</p>
      </footer>
    </div>
  </body>
</html>
