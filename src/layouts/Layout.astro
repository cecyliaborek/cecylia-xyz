---
import '../styles/global.css';
import {
  getBlogUrl,
  getHomeUrl,
  languages,
  ui,
  type Language,
} from '../lib/site';

interface Props {
  title: string;
  description?: string;
  lang: Language;
  active?: 'home' | 'posts';
  alternateUrls?: Partial<Record<Language, string>>;
}

const {
  title,
  description = ui[Astro.props.lang].home.intro,
  lang,
  active,
  alternateUrls = {},
} = Astro.props;
const copy = ui[lang];
const pageTitle =
  title === copy.siteName ? title : `${title} | ${copy.siteName}`;

const navItems = [
  { label: copy.nav.posts, href: getBlogUrl(lang), key: 'posts' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen">
    <div
      class="mx-auto flex min-h-screen w-full max-w-[680px] flex-col px-5 py-5 sm:px-6 sm:py-7"
    >
      <header
        class="flex flex-col gap-4 border-b border-stone-200 pb-5 font-sans text-[13px] sm:flex-row sm:items-center sm:justify-between"
      >
        <a
          class="font-medium tracking-wide no-underline"
          href={getHomeUrl(lang)}
        >
          {copy.navTitle}
        </a>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-3">
          <nav
            class="flex flex-wrap gap-x-4 gap-y-2"
            aria-label={copy.a11y.primaryNavigation}
          >
            {
              navItems.map((item) => (
                <a
                  class:list={[
                    'text-stone-500 no-underline transition hover:text-stone-950',
                    active === item.key && 'text-stone-950',
                  ]}
                  href={item.href}
                  aria-current={
                    active === item.key && item.key === 'posts'
                      ? 'page'
                      : undefined
                  }
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <nav class="flex gap-2 text-xs" aria-label={copy.a11y.languageSwitch}>
            {
              languages.map((language) => (
                <a
                  class:list={[
                    'rounded-full border px-2.5 py-1 no-underline transition',
                    language === lang
                      ? 'border-stone-900 bg-stone-900 text-white'
                      : 'border-stone-300 text-stone-500 hover:border-stone-900 hover:text-stone-950',
                  ]}
                  href={alternateUrls[language] ?? getHomeUrl(language)}
                  aria-current={language === lang ? 'true' : undefined}
                >
                  {language.toUpperCase()}
                </a>
              ))
            }
          </nav>
        </div>
      </header>

      <main class="flex-1 py-10 sm:py-12">
        <slot />
      </main>

      <footer
        id="contact"
        class="flex flex-col gap-3 border-t border-stone-200 py-6 font-sans text-sm text-stone-500 sm:flex-row sm:items-center sm:justify-between"
      >
        <p>
          {copy.home.contact}
          <a class="text-stone-950" href="mailto:hello@example.com"
            >hello@example.com</a
          >
        </p>
        <p>© {new Date().getFullYear()} {copy.siteName}</p>
      </footer>
    </div>
  </body>
</html>
