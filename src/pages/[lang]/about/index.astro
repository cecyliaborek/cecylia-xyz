---
import { getEntry, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import {
  getAboutUrl,
  isLanguage,
  languages,
  ui,
  type Language,
} from '../../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const copy = ui[lang];
const about = await getEntry('about', lang);

if (!about) {
  return Astro.redirect('/404');
}

const { Content } = await render(about);
const alternateUrls: Record<Language, string> = {
  en: getAboutUrl('en'),
  pl: getAboutUrl('pl'),
};
---

<Layout
  title={copy.nav.about}
  description={about.data.description}
  lang={lang}
  active="about"
  alternateUrls={alternateUrls}
>
  <header>
    <h1
      class="font-sans text-[1.625rem] leading-tight font-bold tracking-tight sm:text-[1.875rem]"
    >
      {copy.nav.about}
    </h1>
  </header>

  <div class="about-content mt-8">
    <Content />
  </div>
</Layout>
