---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  formatShortDate,
  getBlogUrl,
  getCategoryLabel,
  getHomeUrl,
  getPostUrl,
  isLanguage,
  languageLabels,
  languages,
  sortPosts,
  ui,
  type Language,
} from '../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const copy = ui[lang];
const posts = sortPosts(await getCollection('blog'));
const featuredPosts = posts.filter(
  (post) => post.data.featured && post.data.language === lang,
);
const alternateUrls: Record<Language, string> = {
  en: getHomeUrl('en'),
  pl: getHomeUrl('pl'),
};
---

<Layout
  title={copy.siteName}
  description={copy.home.intro}
  lang={lang}
  active="home"
  alternateUrls={alternateUrls}
>
  <section class="space-y-4">
    <h1
      class="text-[24px] leading-snug font-normal tracking-normal sm:text-[28px]"
    >
      {copy.siteName}
    </h1>
    <p
      class="font-sans text-[12px] font-medium tracking-[0.12em] text-stone-500 uppercase"
    >
      {copy.home.nouns.join(' · ')}
    </p>
    <p class="max-w-2xl text-[16px] leading-7 text-stone-700">
      {copy.home.intro}
    </p>
    <p class="flex gap-2 font-sans text-[13px] text-stone-500">
      {
        copy.home.socialLinks.map((link, index) => (
          <>
            {index > 0 && <span class="text-stone-300">/</span>}
            <a
              class="no-underline hover:text-stone-950 hover:underline"
              href={link.href}
            >
              {link.label}
            </a>
          </>
        ))
      }
    </p>
  </section>

  <section id="experience" class="mt-12 space-y-4 scroll-mt-8">
    <h2
      class="font-sans text-[13px] font-medium tracking-[0.12em] text-stone-500 uppercase"
    >
      {copy.nav.experience}
    </h2>
    <div class="space-y-4">
      {
        copy.home.experience.map((item) => (
          <p class="border-l border-stone-300 pl-4 text-[16px] leading-7 text-stone-700">
            {item}
          </p>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-center justify-between gap-4">
      <h2
        class="font-sans text-[13px] font-medium tracking-[0.12em] text-stone-500 uppercase"
      >
        {copy.home.featuredPosts}
      </h2>
      <a
        class="font-sans text-sm text-stone-500 hover:text-stone-950"
        href={getBlogUrl(lang)}>{copy.home.latestPosts}</a
      >
    </div>
    <ol class="mt-5 divide-y divide-stone-200">
      {
        featuredPosts.map((post) => (
          <li>
            <a
              class="group grid gap-2 py-4 no-underline transition hover:text-stone-600 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start sm:gap-6"
              href={getPostUrl(post)}
            >
              <span class="min-w-0">
                <span class="block text-[17px] leading-7 text-stone-950 group-hover:underline">
                  {post.data.title}
                </span>
                <span class="mt-1 block font-sans text-[13px] text-stone-500">
                  {getCategoryLabel(post.data.category, lang)} ·{' '}
                  {languageLabels[post.data.language]}
                </span>
              </span>
              <time
                class="font-sans text-[13px] whitespace-nowrap text-stone-500 sm:pt-1"
                datetime={post.data.date.toISOString()}
              >
                {formatShortDate(post.data.date, lang)}
              </time>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
