---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getHomeUrl,
  isLanguage,
  languages,
  type Language,
} from '../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const home = await getEntry('home', lang);

if (!home) {
  return Astro.redirect('/404');
}

const { Content } = await render(home);
const alternateUrls: Record<Language, string> = {
  en: getHomeUrl('en'),
  pl: getHomeUrl('pl'),
};
---

<Layout
  title={home.data.title}
  description={home.data.description}
  lang={lang}
  active="home"
  alternateUrls={alternateUrls}
>
  <div class="home-content">
    <Content />
  </div>
</Layout>
