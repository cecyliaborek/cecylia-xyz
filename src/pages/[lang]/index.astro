---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {
  getBlogUrl,
  getHomeUrl,
  getPostUrl,
  isLanguage,
  languages,
  sortPosts,
  ui,
  type Language,
} from '../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const copy = ui[lang];
const posts = sortPosts(await getCollection('blog'));
const recentPosts = posts
  .filter((post) => post.data.language === lang)
  .slice(0, 5);
const alternateUrls: Record<Language, string> = {
  en: getHomeUrl('en'),
  pl: getHomeUrl('pl'),
};
---

<Layout
  title={copy.siteName}
  description={copy.home.intro}
  lang={lang}
  active="home"
  alternateUrls={alternateUrls}
>
  <header
    class="grid items-start gap-6 sm:grid-cols-[minmax(0,1fr)_11rem] sm:gap-x-10"
  >
    <div>
      <h1
        class="font-sans text-[1.625rem] leading-tight font-bold tracking-tight sm:text-[1.875rem]"
      >
        {copy.siteName}
      </h1>
      <p class="mt-4 text-[1.0625rem] leading-7">
        {copy.home.intro}
      </p>
      <p class="mt-4 flex flex-wrap gap-x-2 gap-y-1 text-[1.0625rem] leading-7">
        {
          copy.home.socialLinks.map((link, index) => (
            <>
              {index > 0 && <span aria-hidden="true">·</span>}
              <a class="text-link underline" href={link.href}>
                {link.label}
              </a>
            </>
          ))
        }
      </p>
    </div>
    <img
      class="aspect-square w-full max-w-[11rem] object-cover sm:w-[11rem] sm:justify-self-end"
      src="/profile.jpg"
      alt={copy.home.profileAlt}
      width="176"
      height="176"
    />
  </header>

  <section class="mt-14 sm:mt-16">
    <h2 class="font-sans text-[1.25rem] font-bold tracking-tight">
      {copy.home.recentPosts}
    </h2>
    <ul class="mt-5 list-none space-y-4 pl-0">
      {
        recentPosts.map((post) => (
          <li class="text-[1.0625rem] leading-7">
            <a class="text-link underline" href={getPostUrl(post)}>
              {post.data.title}
            </a>
            <span> {post.data.excerpt}</span>
          </li>
        ))
      }
    </ul>
    <p class="mt-5 text-[1.0625rem] leading-7">
      <a class="text-link underline" href={getBlogUrl(lang)}>
        {copy.home.allPosts}
      </a>
    </p>
  </section>
</Layout>
