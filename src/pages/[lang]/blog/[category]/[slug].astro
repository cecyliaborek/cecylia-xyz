---
import { getCollection, render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import {
  formatDate,
  getBlogUrl,
  getPostLanguageSwitchUrl,
  ui,
  type BlogPost,
  type Language,
} from '../../../../lib/site';

export async function getStaticPaths() {
  const localPostFiles = import.meta.glob('../../../../content/blog/**/*.md');

  if (Object.keys(localPostFiles).length === 0) {
    return [];
  }

  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: {
      lang: post.data.language,
      category: post.data.category,
      slug: post.data.slug,
    },
    props: { post },
  }));
}

const post = Astro.props.post as BlogPost;
const posts = await getCollection('blog');
const lang = post.data.language as Language;
const copy = ui[lang];
const { Content } = await render(post);
const alternateUrls: Record<Language, string> = {
  en: getPostLanguageSwitchUrl(post, posts, 'en'),
  pl: getPostLanguageSwitchUrl(post, posts, 'pl'),
};
const realTranslations = Object.entries(alternateUrls).filter(
  ([language, url]) =>
    language !== lang && url !== getBlogUrl(language as Language),
);
---

<Layout
  title={post.data.title}
  description={post.data.excerpt ?? post.data.title}
  lang={lang}
  active="posts"
  alternateUrls={alternateUrls}
>
  <article>
    <a
      class="font-sans text-[0.8125rem] text-muted no-underline hover:text-ink hover:underline"
      href={getBlogUrl(lang)}>{copy.post.back}</a
    >
    <header class="border-line mt-6 border-b pb-8">
      <p class="text-muted font-sans text-[0.8125rem]">
        {formatDate(post.data.date, lang)}
      </p>
      <h1
        class="mt-4 text-[1.875rem] leading-tight font-normal tracking-tight sm:text-[2.25rem]"
      >
        {post.data.title}
      </h1>
      {
        post.data.excerpt && (
          <p class="mt-4 text-[1.125rem] leading-8 text-muted">
            {post.data.excerpt}
          </p>
        )
      }
      {
        realTranslations.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2 font-sans text-sm">
            <span>{copy.post.translation}:</span>
            {realTranslations.map(([language, url]) => (
              <a href={url}>{language.toUpperCase()}</a>
            ))}
          </div>
        )
      }
    </header>

    <div class="post-content mt-8">
      <Content />
    </div>
  </article>
</Layout>
