---
import { getCollection } from 'astro:content';
import PostPreview from '../../../components/PostPreview.astro';
import Layout from '../../../layouts/Layout.astro';
import {
  getExternalPosts,
  getLocalPostPreview,
  sortWritingPosts,
} from '../../../lib/posts';
import {
  categories,
  getBlogUrl,
  getCategoryLabel,
  isLanguage,
  languages,
  ui,
  type Language,
} from '../../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const copy = ui[lang];
const localPostFiles = import.meta.glob('../../../content/blog/**/*.md');
const localPosts =
  Object.keys(localPostFiles).length > 0
    ? (await getCollection('blog'))
        .filter((post) => post.data.language === lang)
        .map(getLocalPostPreview)
    : [];
const posts = sortWritingPosts([...getExternalPosts(), ...localPosts]);
const alternateUrls: Record<Language, string> = {
  en: getBlogUrl('en'),
  pl: getBlogUrl('pl'),
};

const activeCategory = 'all';
const categoryFilterLinks = [
  { value: 'all', label: copy.blog.all },
  ...categories.map((category) => ({
    value: category,
    label: getCategoryLabel(category, lang),
  })),
];

function filterUrl(category: string) {
  const params = new URLSearchParams();
  params.set('category', category);
  return `${getBlogUrl(lang)}?${params.toString()}`;
}

function isFilterActive(value: string) {
  return value === activeCategory;
}
---

<Layout
  title={copy.blog.title}
  description={copy.siteName}
  lang={lang}
  active="posts"
  alternateUrls={alternateUrls}
>
  <header>
    <h1
      class="font-sans text-[1.625rem] leading-tight font-bold tracking-tight sm:text-[1.875rem]"
    >
      {copy.blog.title}
    </h1>
  </header>

  <section class="mt-8" aria-label={copy.a11y.postFilters}>
    <p class="text-[1.0625rem] leading-7">
      <span class="font-sans font-bold">{copy.blog.category}:</span>
      {
        categoryFilterLinks.map((item, index) => (
          <>
            {index > 0 && <span aria-hidden="true"> · </span>}
            <a
              class:list={[
                isFilterActive(item.value)
                  ? 'text-link underline'
                  : 'text-ink no-underline hover:underline',
              ]}
              href={filterUrl(item.value)}
              data-filter-category={item.value}
              aria-current={isFilterActive(item.value) ? 'true' : undefined}
            >
              {item.label}
            </a>
          </>
        ))
      }
    </p>
  </section>

  <section class="mt-10 sm:mt-12">
    <ul id="post-list" class="list-none space-y-4 pl-0">
      {posts.map((post) => <PostPreview post={post} locale={lang} />)}
    </ul>
    <p id="empty-state" class="mt-5 hidden text-[1.0625rem] leading-7">
      {copy.blog.noPosts}
    </p>
  </section>

  <script
    is:inline
    define:vars={{
      blogPath: getBlogUrl(lang),
      validCategories: categories,
    }}
  >
    const params = new URLSearchParams(window.location.search);
    const requestedCategory = params.get('category') || 'all';
    const activeCategory =
      requestedCategory === 'all' || validCategories.includes(requestedCategory)
        ? requestedCategory
        : 'all';
    const cards = [...document.querySelectorAll('.post-card')];
    const emptyState = document.querySelector('#empty-state');

    let visibleCount = 0;
    for (const card of cards) {
      const isVisible =
        activeCategory === 'all' || card.dataset.category === activeCategory;
      card.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    }

    emptyState?.classList.toggle('hidden', visibleCount > 0);

    for (const link of document.querySelectorAll('[data-filter-category]')) {
      const value = link.dataset.filterCategory;
      const isActive = value === activeCategory;
      const nextParams = new URLSearchParams({ category: value });

      link.classList.toggle('text-link', isActive);
      link.classList.toggle('text-ink', !isActive);
      link.classList.toggle('underline', isActive);
      link.classList.remove('no-underline');
      if (!isActive) {
        link.classList.add('no-underline');
      }
      link.setAttribute('href', `${blogPath}?${nextParams.toString()}`);
      link.setAttribute('aria-current', isActive ? 'true' : 'false');
    }
  </script>
</Layout>
