---
import { getCollection } from 'astro:content';
import PostPreview from '../../../components/PostPreview.astro';
import Layout from '../../../layouts/Layout.astro';
import {
  categories,
  getBlogUrl,
  getCategoryLabel,
  isLanguage,
  languageLabels,
  languages,
  sortPosts,
  ui,
  type Language,
} from '../../../lib/site';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : 'en';
const copy = ui[lang];
const posts = sortPosts(await getCollection('blog'));
const alternateUrls: Record<Language, string> = {
  en: getBlogUrl('en'),
  pl: getBlogUrl('pl'),
};

const languageFilterLinks = [
  { value: 'all', label: copy.blog.all },
  ...languages.map((language) => ({
    value: language,
    label: languageLabels[language],
  })),
];
const categoryFilterLinks = [
  { value: 'all', label: copy.blog.all },
  ...categories.map((category) => ({
    value: category,
    label: getCategoryLabel(category, lang),
  })),
];

function filterUrl(language: string, category: string) {
  const params = new URLSearchParams();
  params.set('language', language);
  params.set('category', category);
  return `${getBlogUrl(lang)}?${params.toString()}`;
}
---

<Layout
  title={copy.blog.title}
  description={copy.blog.description}
  lang={lang}
  active="posts"
  alternateUrls={alternateUrls}
>
  <section>
    <h1
      class="text-[30px] leading-tight font-normal tracking-normal sm:text-[36px]"
    >
      {copy.blog.title}
    </h1>
  </section>

  <section class="mt-4 space-y-2" aria-label={copy.a11y.postFilters}>
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <p
        class="min-w-[4.75rem] font-sans text-[12px] font-medium tracking-[0.1em] text-stone-500 uppercase"
      >
        {copy.blog.language}
      </p>
      <div class="flex flex-wrap gap-x-2.5 gap-y-1 font-sans text-[13px]">
        {
          languageFilterLinks.map((item, index) => (
            <>
              {index > 0 && <span class="text-stone-300">/</span>}
              <a
                class="filter-link text-stone-500 no-underline transition hover:text-stone-950 hover:underline"
                href={filterUrl(item.value, 'all')}
                data-filter-kind="language"
                data-filter-value={item.value}
              >
                {item.label}
              </a>
            </>
          ))
        }
      </div>
    </div>
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <p
        class="min-w-[4.75rem] font-sans text-[12px] font-medium tracking-[0.1em] text-stone-500 uppercase"
      >
        {copy.blog.category}
      </p>
      <div class="flex flex-wrap gap-x-2.5 gap-y-1 font-sans text-[13px]">
        {
          categoryFilterLinks.map((item, index) => (
            <>
              {index > 0 && <span class="text-stone-300">/</span>}
              <a
                class="filter-link text-stone-500 no-underline transition hover:text-stone-950 hover:underline"
                href={filterUrl(lang, item.value)}
                data-filter-kind="category"
                data-filter-value={item.value}
              >
                {item.label}
              </a>
            </>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mt-5" aria-live="polite">
    <div id="post-list" class="border-t border-stone-200">
      {
        posts.map((post) => (
          <PostPreview
            post={post}
            locale={lang}
            initiallyHidden={post.data.language !== lang}
          />
        ))
      }
    </div>
    <p id="empty-state" class="hidden py-10 text-stone-600">
      {copy.blog.noPosts}
    </p>
  </section>

  <script is:inline define:vars={{ defaultLanguage: lang }}>
    const params = new URLSearchParams(window.location.search);
    const activeLanguage = params.get('language') || defaultLanguage;
    const activeCategory = params.get('category') || 'all';
    const cards = [...document.querySelectorAll('.post-card')];
    const emptyState = document.querySelector('#empty-state');
    const blogPath = `/${defaultLanguage}/blog/`;

    let visibleCount = 0;
    for (const card of cards) {
      const languageMatches =
        activeLanguage === 'all' || card.dataset.language === activeLanguage;
      const categoryMatches =
        activeCategory === 'all' || card.dataset.category === activeCategory;
      const isVisible = languageMatches && categoryMatches;
      card.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    }

    emptyState?.classList.toggle('hidden', visibleCount > 0);

    for (const link of document.querySelectorAll('.filter-link')) {
      const kind = link.dataset.filterKind;
      const value = link.dataset.filterValue;
      const isActive =
        (kind === 'language' && value === activeLanguage) ||
        (kind === 'category' && value === activeCategory);
      const nextLanguage = kind === 'language' ? value : activeLanguage;
      const nextCategory = kind === 'category' ? value : activeCategory;
      const nextParams = new URLSearchParams({
        language: nextLanguage,
        category: nextCategory,
      });

      link.classList.toggle('text-stone-950', isActive);
      link.classList.toggle('underline', isActive);
      link.setAttribute('href', `${blogPath}?${nextParams.toString()}`);
      link.setAttribute('aria-current', isActive ? 'true' : 'false');
    }
  </script>
</Layout>
