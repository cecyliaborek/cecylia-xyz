---
import {
  formatShortDate,
  getCategoryLabel,
  getPostUrl,
  languageLabels,
  type BlogPost,
  type Language,
} from '../lib/site';

interface Props {
  post: BlogPost;
  locale: Language;
  initiallyHidden?: boolean;
  compact?: boolean;
}

const { post, locale, initiallyHidden = false, compact = false } = Astro.props;
const meta = `${getCategoryLabel(post.data.category, locale)} · ${formatShortDate(post.data.date, locale)} · ${languageLabels[post.data.language]}`;
---

<li
  class="post-card text-[1.0625rem] leading-7"
  data-language={post.data.language}
  data-category={post.data.category}
  hidden={initiallyHidden}
>
  <a class="text-link underline" href={getPostUrl(post)}>
    {post.data.title}
  </a>
  <span> {post.data.excerpt}</span>
  {
    !compact && (
      <span class="text-muted">
        {' '}
        · {meta}
      </span>
    )
  }
</li>
