---
import {
  formatShortDate,
  getCategoryLabel,
  getPostUrl,
  languageLabels,
  type BlogPost,
  type Language,
} from '../lib/site';

interface Props {
  post: BlogPost;
  locale: Language;
  initiallyHidden?: boolean;
}

const { post, locale, initiallyHidden = false } = Astro.props;
---

<article
  class="post-card group border-t border-stone-200 first:border-t-0"
  data-language={post.data.language}
  data-category={post.data.category}
  hidden={initiallyHidden}
>
  <a
    class="grid gap-2 py-4 no-underline transition hover:text-stone-600 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start sm:gap-6"
    href={getPostUrl(post)}
  >
    <div class="min-w-0">
      <h2 class="text-[17px] leading-7 font-normal text-stone-950">
        <span class="group-hover:underline">{post.data.title}</span>
      </h2>
      <span class="mt-1 block leading-6 text-stone-600">
        {post.data.excerpt}
      </span>
      <span class="mt-1.5 block font-sans text-[13px] text-stone-500">
        {getCategoryLabel(post.data.category, locale)} · {
          languageLabels[post.data.language]
        }
      </span>
    </div>
    <time
      class="font-sans text-[13px] whitespace-nowrap text-stone-500 sm:pt-1"
      datetime={post.data.date.toISOString()}
    >
      {formatShortDate(post.data.date, locale)}
    </time>
  </a>
</article>
