---
interface Link {
  label: string;
  href: string;
}

interface Props {
  title: string;
  profileAlt: string;
  links: Link[];
}

const { title, profileAlt, links } = Astro.props;
---

<header>
  <h1
    class="font-sans text-[1.625rem] leading-tight font-bold tracking-tight sm:text-[1.875rem]"
  >
    {title}
  </h1>
  <img
    class="float-right mt-1 mb-3 ml-4 aspect-[4/5] w-[6.5rem] rounded-sm object-cover object-center min-[360px]:ml-5 min-[360px]:w-[7.75rem] sm:mt-0 sm:mb-4 sm:ml-8 sm:w-[10.5rem]"
    src="/profile.jpg"
    alt={profileAlt}
    width="168"
    height="210"
  />
  <div class="mt-6">
    <div class="home-hero-copy text-[1.0625rem] leading-7">
      <slot />
    </div>
    <p class="mt-4 flex flex-wrap gap-x-2 gap-y-1 text-[1.0625rem] leading-7">
      {
        links.map((link, index) => (
          <>
            {index > 0 && <span aria-hidden="true">·</span>}
            <a class="text-link underline" href={link.href}>
              {link.label}
            </a>
          </>
        ))
      }
    </p>
  </div>
</header>
